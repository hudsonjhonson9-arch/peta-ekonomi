# Pengaturan Server
PORT=3000

# Konfigurasi Koneksi Database PostgreSQL VPS
# Format: postgresql://username:password@ip_vps:port/nama_database
# Ganti dengan kredensial PostgreSQL yang ada di Coolify/VPS Anda
DATABASE_URL=postgresql://user:password@localhost:5432/peta_ekonomi

# Google Apps Script Web App URL (client-side, Vite env)
# Dapatkan setelah deploy GAS → Deploy → New deployment → Web app
VITE_GAS_WEBAPP_URL=https://script.google.com/macros/s/xxx/exec

# Google Apps Script URL (server-side, untuk proxy di Express)
# Sama dengan VITE_GAS_WEBAPP_URL
# GAS_WEBAPP_URL=

# API Key untuk mengamankan endpoint upload dari GAS ke Express
# Kosongkan jika tidak ingin menggunakan key
UPLOAD_API_KEY=
